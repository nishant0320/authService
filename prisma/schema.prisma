generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

enum TwoFactorMethod {
  NONE
  TOTP
  WHATSAPP
  PASSKEY
}

model User {
  id        String  @id @default(uuid())
  name      String
  email     String  @unique
  phone     String?
  password  String  @map("hashed_password")
  role      Role
  avatarUrl String?

  isActive     Boolean  @default(true)
  lastLogin    DateTime @default(now())
  refreshToken String?

  totpSecret    String?
  isTotpEnabled Boolean @default(false)
  isWhatsappEnabled Boolean @default(false)
  twoFactorMethod   TwoFactorMethod @default(NONE)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  oauthAccounts OAuthAccount[]
  passkeys      PasskeyCredential[]
  auditLog      AuditLog[]

  @@index([email])
  @@index([role])
  @@map("users")
}

model PasskeyCredential {
  id           String @id @default(uuid())
  credentialId String @unique
  publicKey    String
  counter      Int    @default(0)
  transports   String?
  nickname     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("passkey_credentials")
}

model OAuthAccount {
  id       String @id @default(uuid())
  provider String
  oauth    String
  sub      String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([provider])
  @@map("oauth_accounts")
}

model AuditLog {
  id       String @id @default(uuid())
  action   String
  entity   String
  entityId String
  details  Json?

  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([entity])
  @@index([createdAt])
  @@map("audit_logs")
}
